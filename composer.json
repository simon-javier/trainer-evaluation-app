{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "google/apiclient": "^2.15",
        "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/boost": "^2.4",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "C:/Users/Evangeline/.config/herd-lite/bin/php.exe -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "C:/Users/Evangeline/.config/herd-lite/bin/php.exe artisan key:generate",
            "C:/Users/Evangeline/.config/herd-lite/bin/php.exe artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"C:/Users/Evangeline/.config/herd-lite/bin/php.exe artisan serve\" \"C:/Users/Evangeline/.config/herd-lite/bin/php.exe artisan queue:listen --tries=1 --timeout=0\" \"C:/Users/Evangeline/.config/herd-lite/bin/php.exe artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "C:/Users/Evangeline/.config/herd-lite/bin/php.exe artisan config:clear --ansi",
            "C:/Users/Evangeline/.config/herd-lite/bin/php.exe artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "C:/Users/Evangeline/.config/herd-lite/bin/php.exe artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "C:/Users/Evangeline/.config/herd-lite/bin/php.exe artisan vendor:publish --tag=laravel-assets --ansi --force",
            "C:/Users/Evangeline/.config/herd-lite/bin/php.exe artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "C:/Users/Evangeline/.config/herd-lite/bin/php.exe -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "C:/Users/Evangeline/.config/herd-lite/bin/php.exe artisan key:generate --ansi",
            "C:/Users/Evangeline/.config/herd-lite/bin/php.exe -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "C:/Users/Evangeline/.config/herd-lite/bin/php.exe artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
